<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Inventario General"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:padding="16dp"/>

    <HorizontalScrollView
        android:id="@+id/scrollFiltros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTitulo"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btnFiltroTodos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Todos" android:backgroundTint="#1976D2" android:textColor="#FFFFFF" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnFiltroCriticos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Críticos" android:backgroundTint="#333333" android:textColor="#A0A0A0" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnFiltroProximos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Próximos" android:backgroundTint="#333333" android:textColor="#A0A0A0" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnFiltroOk" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OK" android:backgroundTint="#333333" android:textColor="#A0A0A0"/>
        </LinearLayout>
    </HorizontalScrollView>

    <ListView
        android:id="@+id/lvInventario"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/scrollFiltros"
        android:layout_above="@id/bottom_navigation"
        android:padding="16dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"/>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#1E1E1E"
        app:itemIconTint="#A0A0A0"
        app:itemTextColor="#A0A0A0"
        app:menu="@menu/menu_navegacion" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnExportarPDF"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottom_navigation"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_menu_save"
        app:backgroundTint="#D32F2F"
        app:tint="#FFFFFF" />

</RelativeLayout>