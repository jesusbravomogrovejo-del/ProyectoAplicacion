<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#2C2C2C"> <TextView
    android:id="@+id/tvDialogNombre"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Nombre del Producto"
    android:textColor="#FFFFFF"
    android:textSize="20sp"
    android:textStyle="bold"
    android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:drawable/dialog_holo_dark_frame"
        android:padding="12dp">

        <TextView android:id="@+id/tvDialogVencimiento" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:text="Fecha de vencimiento: 00/00/0000" android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/tvDialogDias" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:text="Días restantes: 0" android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/tvDialogUbicacion" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:text="Ubicación: Pasillo X" android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/tvDialogCategoria" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:text="Categoría: Abarrotes" />
        <TextView
            android:id="@+id/tvDialogStock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stock en sistema: 0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:weightSum="2">

        <Button
            android:id="@+id/btnDialogEditar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Editar"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnDialogEliminar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Eliminar registro"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>